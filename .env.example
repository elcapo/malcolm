# Required: backend URL to proxy requests to
MALCOLM_TARGET_URL=https://openrouter.ai/api/v1

# Required if backend needs auth (otherwise forwards client's Authorization header)
MALCOLM_TARGET_API_KEY=sk-or-...

# Optional: server configuration
MALCOLM_HOST=127.0.0.1
MALCOLM_PORT=8900

# Optional: SQLite storage
MALCOLM_STORAGE_ENABLED=true
MALCOLM_DB_PATH=malcolm.db

# Optional: logging
MALCOLM_LOG_LEVEL=info
